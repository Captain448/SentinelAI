# SentinelAI Environment Variables Example
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# Database Connection (PostgreSQL or SQLite fallback)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinel_db
# Async Database Connection (for async FastAPI routers)
ASYNC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/sentinel_db

# Redis Connection (or in-memory mock if empty/unavailable)
REDIS_URL=redis://localhost:6379/0

# Simulation Settings
SIMULATION_SPEED_MULTIPLIER=1.0
